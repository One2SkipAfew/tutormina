# ============================================
# TutorMina — Root .gitignore
# ============================================

# Dependencies
node_modules/

# Environment files (secrets)
.env
.env.local
.env.*.local

# OS Files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
ai-api/venv/

# Supabase local (Docker volumes & data)
supabase/.temp/
supabase/.branches/

# Build outputs
frontend/dist/
ai-api/dist/

# Logs
*.log
npm-debug.log*
