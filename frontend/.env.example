# Supabase (local dev instance, via `npx supabase start`)
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key_here

# Daily.co (video meetings) - server-side only in production, see note below
VITE_DAILY_API_KEY=your_daily_api_key_here

# Paystack (public key only - safe to expose client-side)
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# AI API (local FastAPI server)
VITE_AI_API_URL=http://127.0.0.1:8000

# NOTE: Daily.co API keys are secret, not public - do not ship a VITE_ prefixed
# key to production. Room-creation calls should go through ai-api instead.
