# ============================================
# TutorMina AI API — Environment Variables
# ============================================

# Gemini API Key (required) — Get free from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Local Supabase (for development)
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_SERVICE_ROLE_KEY=your_local_supabase_service_role_key_here

# Deepgram (optional, for real-time WebSocket transcription)
# Get from https://console.deepgram.com — free $200 credit
DEEPGRAM_API_KEY=

# Serper (optional, for web search fact-checking)
# Get from https://serper.dev — free tier available
SERPER_API_KEY=

# HuggingFace token (legacy, not needed for Gemini)
HF_TOKEN=

# Environment flag
ENVIRONMENT=development

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
